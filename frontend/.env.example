# Build-time variables (set before npm run build on VPS)

# Backend API — use your live API URL (no trailing slash)
# If nginx on same domain proxies /api to Node, you can leave empty:
# VITE_API_URL=
VITE_API_URL=https://northparadisetreksandtours.com

# Canonical public website URL (SEO, optional)
VITE_SITE_URL=https://northparadisetreksandtours.com

# WhatsApp number digits only (no +)
VITE_WHATSAPP_NUMBER=923488142776

# --- Local development ---
# Use .env.development (included) or copy:
# VITE_API_URL=              # empty = use /api via Vite proxy
# VITE_API_PROXY_TARGET=http://localhost:5000
# VITE_SITE_URL=http://localhost:3000
# Restart `npm run dev` after changing env or vite.config.ts
