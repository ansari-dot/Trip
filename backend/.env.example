# === Hostinger VPS production example ===
PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://127.0.0.1:27017/north-paradise
JWT_SECRET=change-me-long-random-string

# Public URL where uploads are served (no trailing slash)
# Same as main site if nginx proxies /api and /uploads to this app:
PUBLIC_URL=https://northparadisetreksandtours.com
# Or dedicated API subdomain:
# PUBLIC_URL=https://api.northparadisetreksandtours.com

# Comma-separated browser origins allowed (no trailing slashes)
CLIENT_URL=https://northparadisetreksandtours.com,https://www.northparadisetreksandtours.com,https://admin.northparadisetreksandtours.com

# Marketing site URL for AI trip planner links in prompts
CLIENT_SITE_URL=https://northparadisetreksandtours.com

# Optional extra CORS origins
# ALLOWED_ORIGINS=

# Local dev only (ignored when NODE_ENV=production)
# DEV_ORIGINS=http://localhost:3000,http://localhost:3001

# Groq AI trip planner
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Email (if configured)
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
